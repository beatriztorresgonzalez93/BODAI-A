MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app-name>
MONGODB_DB_NAME=wedding_site
ADMIN_USER=novios
ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
ADMIN_SESSION_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO

# Fotos: opcional. Con las tres variables, las subidas van a Cloudinary (API servidor; NO hace falta crear un "upload preset").
# CLOUDINARY_CLOUD_NAME=   <- solo el nombre corto (ej. abc123), sin https ni .cloudinary.com
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=boda-fotos   <- carpeta virtual en Media Library (se crea al subir la primera foto)
